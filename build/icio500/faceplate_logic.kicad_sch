  (text "ICIO500 Faceplate Logic Board\nFront-panel satellite for Electro-Smith Daisy\nRev 0.1" (at 15 15 0) (uuid "06de9e36-41df-40ea-a6e6-8d417e7c6e53") (effects (font (size 2 2) (bold yes))))
  (text "NOTE: All LEDs are 0805 forward-biased\nfrom IS31FL3236 constant-current outputs.\n33R resistors fine-tune brightness." (at 140 5 0) (uuid "955090c4-3297-4d51-ab34-1f15486ae689") (effects (font (size 1.5 1.5))))
  (text "NOTE: ENC_A, ENC_B, ENC_SW route directly\nto Daisy GPIO via JST connector.\nDaisy handles quadrature decode in firmware." (at 15 145 0) (uuid "b2dfc416-b08b-407a-b1b5-d9e14a0a0030") (effects (font (size 1.5 1.5))))
  (text "I2C bus (SDA/SCL)\nIS31FL3236 addr: 0x3C (AD=GND)\n4.7k pull-ups to 3V3" (at 78 15 0) (uuid "9b2bb37f-d8ed-436b-b433-e2380a3fdfa2") (effects (font (size 1.5 1.5))))
