# Temporary files
*.000
*.bak
*.bck
*.kicad_pcb-bak
*.sch-bak
*~
_autosave-*
*.tmp
*-save.pro
*-save.kicad_pcb
fp-info-cache

*.openjds21
# Netlist files (exported from Eeschema)
*.net

# Autorouter files (exported from Pcbnew)
*.dsn
*.ses

# Exported BOM files
*.xml
*.csv

# Atopile build artifacts
build/
.ato/

# Python virtual environment
.venv/
venv/
env/

# Large files and archives
*.jar
*.zip

# Logs and text output
*.log
logs/
drc*.txt
error.txt

